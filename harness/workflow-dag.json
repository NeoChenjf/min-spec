{
  "schema": "min-spec-workflow-dag-v1",
  "version": "0.2.0",
  "stages": {
    "clarify": {
      "name": "需求澄清",
      "next": ["plan"],
      "checkpoint": "mandatory_review",
      "required_outputs": ["clarification"],
      "skill": "skill/clarify/SKILL.md",
      "writes": ["docs/meta/requirements/{run_id}-clarification.md"]
    },
    "plan": {
      "name": "实现计划拆分",
      "next": ["build"],
      "checkpoint": "mandatory_review",
      "required_outputs": ["impl_plan"],
      "skill": "skill/impl-plan/SKILL.md",
      "writes": ["docs/meta/requirements/{run_id}-impl-plan.md"]
    },
    "build": {
      "name": "Phase 编码循环",
      "next": ["verify"],
      "checkpoint": "phase_review",
      "required_outputs": ["changeset"],
      "skill": "skill/impl/SKILL.md",
      "review_skill": "skill/review/SKILL.md",
      "writes": ["docs/meta/sessions/{run_id}.jsonl"]
    },
    "verify": {
      "name": "门禁验证",
      "next": ["retrospect"],
      "checkpoint": "mandatory_review",
      "required_outputs": ["gate_card"],
      "writes": [
        "docs/meta/gates/{run_id}-gate.md",
        "docs/meta/sessions/{run_id}.jsonl"
      ]
    },
    "retrospect": {
      "name": "交付复盘沉淀",
      "next": [],
      "checkpoint": "recommended_review",
      "required_outputs": ["retro"],
      "skill": "skill/retro/SKILL.md",
      "writes": [
        "docs/meta/retro/{run_id}-retro.md",
        "docs/meta/knowledge/lessons.md",
        "docs/meta/sessions/{run_id}.jsonl"
      ]
    }
  }
}
